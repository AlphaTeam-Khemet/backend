* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: system-ui, -apple-system, sans-serif; padding: 1rem; max-width: 960px; margin: 0 auto; color: #333; }
nav { padding: 1rem 0; border-bottom: 1px solid #ddd; margin-bottom: 1.5rem; }
nav a { margin-right: 1.5rem; text-decoration: none; color: #b8860b; font-weight: 500; }
nav a:hover { text-decoration: underline; }
h1 { margin-bottom: 1rem; color: #1a1a1a; }
.btn { display: inline-block; padding: 0.5rem 1rem; background: #b8860b; color: #fff; text-decoration: none; border-radius: 4px; margin-top: 1rem; }
.btn:hover { background: #996f0a; }
.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1.5rem; margin-top: 1rem; }
.card { border: 1px solid #ddd; border-radius: 8px; padding: 1rem; transition: box-shadow 0.2s; }
.card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
.card img { width: 100%; height: 180px; object-fit: cover; border-radius: 4px; margin-bottom: 0.5rem; }
.card h2 { font-size: 1.1rem; margin-bottom: 0.25rem; }
.card h2 a { text-decoration: none; color: #1a1a1a; }
.card h2 a:hover { color: #b8860b; }
.card p { color: #666; font-size: 0.9rem; }
