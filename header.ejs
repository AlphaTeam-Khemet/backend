const router = require('express').Router();
const auth = require('../middleware/auth');
const ctrl = require('../controllers/aiGuideController');

router.get('/health', ctrl.health);
router.get('/conversations', auth, ctrl.getConversations);
router.get('/conversations/:id/messages', auth, ctrl.getConversationMessages);
router.patch('/conversations/:id/title', auth, ctrl.updateConversationTitle);
router.delete('/conversations/:id', auth, ctrl.deleteConversation);
router.post('/ask', auth, ctrl.askQuestion);
router.post('/describe', auth, ctrl.describeMonument);
router.post('/identify', auth, ctrl.identifyMonument);

module.exports = router;
